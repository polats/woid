# Copy to .env and fill in.
# docker compose reads this file automatically when run from this directory.

NVIDIA_NIM_API_KEY=
GEMINI_API_KEY=

# Optional. Enables the `local` provider in the sandbox Settings panel.
# If you run the bundled llama.cpp stack on the host (see
# agent-sandbox/llama-cpp/), set this to:
#   LOCAL_LLM_BASE_URL=http://host.docker.internal:18080/v1
# Leave blank to hide the Local provider option.
LOCAL_LLM_BASE_URL=
