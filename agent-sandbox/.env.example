# Copy to .env and fill in.
# docker compose reads this file automatically when run from this directory.

NVIDIA_NIM_API_KEY=
GEMINI_API_KEY=

# Optional. Enables the `local` provider in the sandbox Settings panel.
# Run the bundled llama.cpp stack on the host (see agent-sandbox/llama-cpp/),
# then set one of:
#   LOCAL_LLM_BASE_URL=http://172.17.0.1:18080/v1            (Linux default docker bridge)
#   LOCAL_LLM_BASE_URL=http://host.docker.internal:18080/v1  (Docker Desktop on macOS/Windows)
# pi-bridge probes the URL at boot and falls back from host.docker.internal
# to 172.17.0.1 automatically if resolution fails. Leave blank to hide the
# Local provider option.
LOCAL_LLM_BASE_URL=

# Optional. S3-compatible object store for character avatar bytes.
# When all five are set, pi-bridge uploads new avatars to the bucket
# and serves from it with a 7-day immutable cache. When any are
# missing, pi-bridge falls back to storing/serving from the local
# $WORKSPACE volume — which is fine for local dev and single-replica
# prod, but shifts to S3 when you want stateless horizontal scaling
# or are already on Railway's bucket service. Credentials for Railway
# buckets: query the `bucketS3Credentials` GraphQL field (see RAILWAY.md).
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Required to spawn agents with harness: "external". Generate once
# with `openssl rand -hex 32` and set the same value in prod env.
# Rotating the secret invalidates all in-flight agent tokens.
AGENT_TOKEN_SECRET=
