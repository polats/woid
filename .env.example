# ─── Frontend (Vite) ──────────────────────────────────────────────
# Overrides for woid.config.json > agentSandbox. All optional; when
# unset, the JSON defaults (localhost ports) are used. Set these in
# Vercel's project env for production so the bundle points at Railway.
VITE_ROOM_SERVER_URL=
VITE_BRIDGE_URL=
VITE_RELAY_URL=
VITE_JUMBLE_URL=
VITE_DEFAULT_ROOM=

# ─── Deployment provider tokens (local tooling only) ──────────────
# Used by manual/CLI workflows from this repo — never committed.
RAILWAY_TOKEN=
VERCEL_TOKEN=
CLOUDFLARE_TOKEN=
